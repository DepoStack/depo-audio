<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow the app to be run without a hardened runtime exception -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
    <!-- Allow reading/writing user-selected files -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- Allow reading/writing to Downloads folder -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
    <!-- Allow executing embedded sidecar binaries (ffmpeg, ffprobe) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Allow loading ONNX Runtime dynamic library -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Inherit entitlements for child processes (ffmpeg sidecar) -->
    <key>com.apple.security.inherit</key>
    <true/>
    <!-- Allow JIT for ONNX Runtime CoreML execution provider -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
</dict>
</plist>
